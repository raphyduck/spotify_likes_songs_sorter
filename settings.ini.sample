; Configure only the service(s) you intend to use. At launch you pick Spotify
; or Tidal; the genre providers and clustering settings below are shared.

[SPOTIFY]
CLIENT_ID = clientid
CLIENT_SECRET = clientsecret
REDIRECT_URI = http://127.0.0.1:8080/

[TIDAL]
; Tidal authentication uses the built-in device OAuth flow and needs no
; client id/secret. Optionally set where the OAuth session is cached so you
; only authorize once. Defaults to ~/.tidal_sorter_session.json when omitted.
; session_file = ~/.tidal_sorter_session.json
;
; Tidal exposes no genre metadata. If you fill in the [SPOTIFY] CLIENT_ID /
; CLIENT_SECRET above, the Tidal run additionally cross-looks up Spotify
; genres FIRST (via the Client Credentials flow — no Spotify login needed):
; album-level genres (album matched by name + artist) take priority, then
; artist-level. Leave the Spotify placeholders untouched to disable this.

[LASTFM]
API_KEY = api_key

[DISCOGS]
API_KEY = api_key

[CLUSTERING]
segmentation_strength = 0.6
max_clusters = 10
; Extra weight given to each album's genre ROOT family (e.g. all *punk* -> punk)
; when computing album similarity. Higher = albums of the same broad family stay
; closer together, reducing fragmentation. 0 disables root weighting. Default 2.0.
genre_root_weight = 2.0
; Optional path to a custom root-family mapping (defaults to genre_roots.json).
; genre_roots_file = genre_roots.json

[GENRE]
; Manual genre overrides (absolute priority over providers and root inference).
; Defaults to genre_overrides.json; edit that file to pin tags/root per artist.
; overrides_file = genre_overrides.json
; Resolution strategy: first_match (default, fast) or consensus (merge several
; providers by weighted vote — more accurate, more HTTP calls; results cached).
; resolution = first_match

[CACHE]
; Persistent genre cache so repeat runs don't re-fetch genres (15-20 min -> seconds).
; backend: redis | file | none
backend = redis
redis_url = redis://localhost:6379/0
; ttl_days applies to found genres; negative (not-found) results use a short TTL
; so they get retried. Override the file location with file_path if desired.
ttl_days = 90
negative_ttl_hours = 6
; file_path = ~/.cache/likes_songs_sorter/genre_cache.json
;
; If Redis is unreachable the run automatically falls back to the file cache.
; CLI overrides: --refresh-cache (re-fetch & overwrite), --no-cache (disable).

; The iTunes Search fallback requires no API key and needs no configuration.
