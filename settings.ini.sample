[TIDAL]
; Optional. Path where the OAuth session is cached so you only authorize once.
; Defaults to ~/.tidal_sorter_session.json when omitted.
; session_file = ~/.tidal_sorter_session.json

[LASTFM]
API_KEY = api_key

[DISCOGS]
API_KEY = api_key

[CLUSTERING]
segmentation_strength = 0.6
max_clusters = 10

; Tidal authentication uses the built-in device OAuth flow and needs no
; client id/secret. The iTunes Search fallback also requires no API key.
