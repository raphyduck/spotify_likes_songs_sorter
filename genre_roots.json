    {"root": "gospel",      "keywords": ["gospel", "worship", "ccm", "christian", "spiritual"]},
    {"root": "latin",       "keywords": ["latin", "salsa", "cumbia", "reggaeton", "reggaetón", "bachata", "merengue", "tango", "flamenco", "ranchera", "mariachi", "español", "espanol", "tropical"]},
    {"root": "schlager",    "keywords": ["schlager", "volksmusik"]},
    {"root": "chanson_fr",  "keywords": ["chanson", "variété", "variete", "french pop", "française", "francais", "nouvelle chanson"]},
    {"root": "hip hop",     "keywords": ["hip hop", "hip-hop", "rap", "trap", "drill", "grime"]},
