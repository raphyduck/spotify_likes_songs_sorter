    {"root": "classical",   "keywords": ["classical", "baroque", "orchestral", "opera", "symphony", "contemporary classical", "romantic era"]},
    {"root": "electronic",  "keywords": ["electronic", "electro", "house", "techno", "trance", "edm", "dubstep", "drum and bass", "dnb", "synth", "idm", "ambient", "downtempo", "garage", "trip hop", "big beat"]},
